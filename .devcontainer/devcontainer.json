{
  "name": "MotorsportHub (Blazor / .NET 8)",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-8.0",
  "forwardPorts": [5080],
  "portsAttributes": {
    "5080": {
      "label": "MotorsportHub",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "dotnet restore MotorsportHub.sln",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit"
      ],
      "settings": {
        "dotnet.defaultSolution": "MotorsportHub.sln"
      }
    }
  }
}
