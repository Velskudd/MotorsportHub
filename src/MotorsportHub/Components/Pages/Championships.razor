@page "/championnats"
@inject ChampionshipService Service

<PageTitle>Championnats — MotorsportHub</PageTitle>

<h1>Les championnats</h1>

<div class="filters">
    <input class="search"
           type="search"
           placeholder="Rechercher un championnat, un organisateur..."
           @bind="_recherche"
           @bind:event="oninput" />

    <div class="chips">
        <button class="chip @(_categorie is null ? "active" : "")"
                @onclick="() => _categorie = null">
            Tous
        </button>
        @foreach (var cat in Enum.GetValues<ChampionshipCategory>())
        {
            var c = cat;
            <button class="chip @(_categorie == c ? "active" : "")"
                    @onclick="() => _categorie = c">
                @c.Emoji() @c.Libelle()
            </button>
        }
    </div>
</div>

<p class="result-count">
    @Resultats.Count championnat@(Resultats.Count > 1 ? "s" : "") trouvé@(Resultats.Count > 1 ? "s" : "")
</p>

<div class="card-grid">
    @foreach (var championnat in Resultats)
    {
        <a class="card" href="/championnats/@championnat.Slug">
            <span class="badge">@championnat.Categorie.Emoji() @championnat.Categorie.Libelle()</span>
            <h2>@championnat.Nom</h2>
            <p>@championnat.Description</p>
            <span class="card-meta">@championnat.Organisateur</span>
        </a>
    }
</div>

@if (Resultats.Count == 0)
{
    <p class="empty">Aucun championnat ne correspond à votre recherche.</p>
}

@code {
    private string _recherche = string.Empty;
    private ChampionshipCategory? _categorie;

    private IReadOnlyList<Championship> Resultats =>
        Service.Rechercher(_recherche, _categorie);
}
