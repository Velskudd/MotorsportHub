@page "/"
@inject PlateauxService Service

<PageTitle>MotorsportHub — Les championnats de sport auto en France</PageTitle>

<section class="hero">
    <p class="hero-kicker">L'annuaire du sport automobile français</p>
    <h1>Tous les championnats<br />de France de sport auto</h1>
    <p class="hero-sub">
        Du GT au rallye, de la course de côte au karting : la base de référence
        des plateaux disputés dans l'Hexagone.
    </p>
    <p class="hero-stats">
        <strong>@_totalPlateaux</strong> championnats
        <span class="sep">•</span>
        <strong>@_parDiscipline.Count</strong> disciplines
        <span class="sep">•</span>
        <strong>@_totalOrganisateurs</strong> organisateurs
    </p>
    <div class="hero-actions">
        <a class="cta" href="/championnats">Explorer les championnats</a>
        <a class="cta cta--ghost" href="/a-propos">À propos du projet</a>
    </div>
</section>

<section class="disciplines">
    <h2>Par discipline</h2>
    <div class="d-grid">
        @foreach (var element in _parDiscipline)
        {
            <a class="d-tile tile--@element.Discipline.Slug"
               href="/championnats?discipline=@element.Discipline.Slug">
                <span class="d-emoji">@element.Discipline.Emoji</span>
                <span class="d-name">@element.Discipline.Nom</span>
                <span class="d-count">@element.Nombre championnat@(element.Nombre > 1 ? "s" : "")</span>
            </a>
        }
    </div>
</section>

@code {
    private IReadOnlyList<DisciplineAvecNombre> _parDiscipline = [];
    private int _totalPlateaux;
    private int _totalOrganisateurs;

    protected override async Task OnInitializedAsync()
    {
        _parDiscipline = await Service.CompterParDisciplineAsync();
        _totalPlateaux = _parDiscipline.Sum(e => e.Nombre);

        var tous = await Service.ObtenirTousAsync();
        _totalOrganisateurs = tous
            .SelectMany(p => p.Organisateurs)
            .Distinct()
            .Count();
    }
}
