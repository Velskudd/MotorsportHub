@page "/"
@inject ChampionnatsService Service

<PageTitle>MotorsportHub — Les championnats de sport auto en France</PageTitle>

<section class="hero">
    <h1>Tous les championnats de sport automobile en France</h1>
    <p>
        Du GT au rallye, de la course de côte au karting : MotorsportHub répertorie
        <strong>@_total championnats et séries</strong> disputés dans l'Hexagone.
    </p>
    <a class="cta" href="/championnats">Explorer les championnats</a>
</section>

<section class="category-overview">
    <h2>Par discipline</h2>
    <div class="category-grid">
        @foreach (var element in _parDiscipline)
        {
            <a class="category-tile" href="/championnats">
                <span class="category-emoji">@element.Discipline.Emoji</span>
                <span class="category-name">@element.Discipline.Nom</span>
                <span class="category-count">@element.Nombre championnat@(element.Nombre > 1 ? "s" : "")</span>
            </a>
        }
    </div>
</section>

@code {
    private IReadOnlyList<DisciplineAvecNombre> _parDiscipline = [];
    private int _total;

    protected override async Task OnInitializedAsync()
    {
        _parDiscipline = await Service.CompterParDisciplineAsync();
        _total = _parDiscipline.Sum(e => e.Nombre);
    }
}
