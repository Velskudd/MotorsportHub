@page "/championnats"
@inject PlateauxService Service
@inject NavigationManager NavManager

<PageTitle>Championnats — MotorsportHub</PageTitle>

<div class="page-head">
    <h1>Championnats</h1>
    <p class="page-sub">Tous les championnats et grandes séries disputés en France.</p>
</div>

<div class="toolbar">
    <input class="search"
           type="search"
           placeholder="Rechercher un championnat, un organisateur..."
           value="@_texte"
           @oninput="SurSaisie" />

    <div class="chips">
        <button class="chip @(_disciplineSlug is null ? "active" : "")"
                @onclick="() => ChoisirDiscipline(null)">
            Tous
        </button>
        @foreach (var d in _disciplines)
        {
            var discipline = d;
            <button class="chip @(_disciplineSlug == discipline.Slug ? "active" : "")"
                    @onclick="() => ChoisirDiscipline(discipline.Slug)">
                @discipline.Emoji @discipline.Nom
            </button>
        }
    </div>
</div>

<p class="result-count">
    @_resultats.Count championnat@(_resultats.Count > 1 ? "s" : "")
</p>

@if (_resultats.Count > 0)
{
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th class="col-nom">Championnat</th>
                    <th>Discipline</th>
                    <th class="col-orga">Organisation</th>
                    <th class="col-depuis">Depuis</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var plateau in _resultats)
                {
                    <tr class="row-link" @onclick="() => Ouvrir(plateau.Slug)">
                        <td class="col-nom">
                            <a class="row-title" href="/championnats/@plateau.Slug" @onclick:stopPropagation>
                                @plateau.Nom
                            </a>
                            <span class="row-desc">@plateau.Description</span>
                        </td>
                        <td>
                            <span class="tag tag--@plateau.Discipline.Slug">
                                @plateau.Discipline.Emoji @plateau.Discipline.Nom
                            </span>
                        </td>
                        <td class="col-orga">@string.Join(", ", plateau.Organisateur.Nom))</td>
                        <td class="col-depuis">@(plateau.AnneeCreation?.ToString() ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="empty">Aucun championnat ne correspond à votre recherche.</p>
}

@code {
    [SupplyParameterFromQuery(Name = "discipline")]
    public string? DisciplineInitiale { get; set; }

    private IReadOnlyList<Discipline> _disciplines = [];
    private IReadOnlyList<Plateau> _resultats = [];
    private string _texte = string.Empty;
    private string? _disciplineSlug;

    protected override async Task OnInitializedAsync()
    {
        _disciplines = await Service.ObtenirDisciplinesAsync();
        _disciplineSlug = DisciplineInitiale;
        await RafraichirAsync();
    }

    private async Task SurSaisie(ChangeEventArgs e)
    {
        _texte = e.Value?.ToString() ?? string.Empty;
        await RafraichirAsync();
    }

    private async Task ChoisirDiscipline(string? slug)
    {
        _disciplineSlug = slug;
        await RafraichirAsync();
    }

    private async Task RafraichirAsync()
    {
        _resultats = await Service.RechercherAsync(_texte, _disciplineSlug);
    }

    private void Ouvrir(string slug) =>
        NavManager.NavigateTo($"/championnats/{slug}");
}
