@page "/championnats/{Slug}"
@inject PlateauxService Service

@if (_plateau is null)
{
    <PageTitle>Championnat introuvable — MotorsportHub</PageTitle>
    <h1>Championnat introuvable</h1>
    <p>Aucun championnat ne correspond à cette adresse.</p>
    <a class="back-link" href="championnats">← Retour à la liste</a>
}
else
{
    <PageTitle>@_plateau.Nom — MotorsportHub</PageTitle>

    <a class="back-link" href="championnats">← Tous les championnats</a>

    <article class="detail tile--@_plateau.Discipline.Slug">
        <header class="detail-head">
            <span class="tag tag--@_plateau.Discipline.Slug">
                @_plateau.Discipline.Emoji @_plateau.Discipline.Nom
            </span>
            @if (_plateau.Statut == StatutPlateau.Disparu)
            {
                <span class="tag tag--disparu">Disparu</span>
            }
            <h1>@_plateau.Nom</h1>
            <p class="detail-meta">
                Organisé par <strong>@_plateau.Organisateur.Nom</strong>
                @if (_plateau.AnneeCreation is int annee)
                {
                    <span class="sep">•</span>
                    <span>Depuis <strong>@annee</strong></span>
                }
                @if (!string.IsNullOrEmpty(_plateau.SiteWeb))
                {
                    <span class="sep">•</span>
                    <a href="@_plateau.SiteWeb" target="_blank" rel="noopener">Site officiel ↗</a>
                }
            </p>
        </header>

        <p class="detail-description">@_plateau.Description</p>
    </article>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private Plateau? _plateau;

    protected override async Task OnParametersSetAsync()
    {
        _plateau = await Service.ObtenirParSlugAsync(Slug);
    }
}
