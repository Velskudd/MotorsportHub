@page "/championnats/{Slug}"
@inject ChampionnatsService Service

@if (_championnat is null)
{
    <PageTitle>Championnat introuvable — MotorsportHub</PageTitle>
    <h1>Championnat introuvable</h1>
    <p>Aucun championnat ne correspond à cette adresse.</p>
    <a class="back-link" href="/championnats">← Retour à la liste</a>
}
else
{
    <PageTitle>@_championnat.Nom — MotorsportHub</PageTitle>

    <a class="back-link" href="/championnats">← Tous les championnats</a>

    <article class="detail">
        <span class="badge">@_championnat.Discipline.Emoji @_championnat.Discipline.Nom</span>
        <h1>@_championnat.Nom</h1>

        <dl class="detail-facts">
            <dt>Organisateur@(_championnat.Organisateurs.Count > 1 ? "s" : "")</dt>
            <dd>@string.Join(", ", _championnat.Organisateurs.Select(o => o.Nom))</dd>

            @if (_championnat.AnneeCreation is int annee)
            {
                <dt>Création</dt>
                <dd>@annee</dd>
            }

            @if (_championnat.Statut == StatutChampionnat.Disparu)
            {
                <dt>Statut</dt>
                <dd>Disparu</dd>
            }

            @if (!string.IsNullOrEmpty(_championnat.SiteWeb))
            {
                <dt>Site officiel</dt>
                <dd><a href="@_championnat.SiteWeb" target="_blank" rel="noopener">@_championnat.SiteWeb</a></dd>
            }
        </dl>

        <p class="detail-description">@_championnat.Description</p>
    </article>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private Championnat? _championnat;

    protected override async Task OnParametersSetAsync()
    {
        _championnat = await Service.ObtenirParSlugAsync(Slug);
    }
}
